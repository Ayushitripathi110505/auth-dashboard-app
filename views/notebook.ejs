<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        transition: background-color 0.3s, color 0.3s;
        background-color: #f0f4f8;
        color: #1a1a1a;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    body.dark-mode {
        background-color: #0d1b2a;
        color: #e0e0e0;
    }

    /* Header */
    .header {
        width: 100%;
        min-height: 220px;
        background: linear-gradient(135deg, #0d1b2a, #1b365d);
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-around;
        position: relative;
        text-align: center;
       /* padding: 30px 20px;*/
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
       /* border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;*/
    }

    /* Top-right buttons */
    .top-right {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .top-right button {
        padding: 8px 15px;
        font-size: 1em;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        transition: background 0.3s, color 0.3s, transform 0.2s;
    }

    .top-right button:hover {
        transform: scale(1.05);
    }

    .dark-mode-btn {
        background-color: #f0f4f8;
        color: #0d1b2a;
    }

    body.dark-mode .dark-mode-btn {
        background-color: #1b365d;
        color: #f0f4f8;
    }

    .logout-btn {
        background-color: #ff4e4e;
        color: #fff;
    }

    .logout-btn:hover {
        background-color: #e03a3a;
    }

    /* Typewriter effect */
    .typewriter h1 {
        overflow: hidden;
        border-right: .15em solid white;
        white-space: nowrap;
        animation: typing 3s steps(20, end), blink-caret 0.75s step-end infinite;
        font-size: 2.5em;
        margin: 0;
        letter-spacing: 2px;
    }

    @keyframes typing {
        from { width: 0 }
        to { width: 100% }
    }

    @keyframes blink-caret {
        50% { border-color: transparent }
    }

    /* Subheading */
    h2 {
        margin-top: 10px;
        font-size: 1.5em;
        font-weight: 500;
        color: #ffd700;
    }

    body.dark-mode .subheading {
        color: #ffcc00;
    }

   
.notebook {
    width: 90%;
    margin-left: 40px;
    margin-right: 40px;
    margin-top: 40px;
    height: 500px;
    padding: 40px 20px 20px 60px;
    font-size: 18px;
    line-height: 30px;
    border: none;
    border-radius: 8px;
    resize: none;
    outline: none;
    font-family: 'Segoe UI', sans-serif;
     border-radius: 12px;

    
    background-color: #fffdf5;

    
    background-image: 
        linear-gradient(to bottom, transparent 29px, #cfd8dc 30px),
        linear-gradient(to right, #ff4e4e 50px, transparent 50px);

    background-size: 100% 30px, 100% 100%;

    box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

/* Dark mode notebook */
body.dark-mode .notebook {
    background-color: #1e293b;
    color: #ffffff;
    background-image: 
        linear-gradient(to bottom, transparent 29px, #3b4a5a 30px),
        linear-gradient(to right, #ff6b6b 50px, transparent 50px);
}

</style>
</head>
<body>

    <div class="header">
        <!-- Top-right buttons -->
        <div class="top-right">
            <button class="dark-mode-btn" onclick="toggleDarkMode()">Toggle Mode</button>
            <button class="logout-btn" onclick="location.href='/auth/login'">Logout</button>
        </div>

        <!-- Welcome and user name -->
        <div class="typewriter">
            <h1> Oh thinging about something <%= user.name %>??</h1>
       <!-- </div>
        <div class="subheading">-->
            <h2>Jot down your thoughts here</h2>
        </div>
    </div>

    <!-- Main content -->
   <!-- Main content -->
<div class="content" style="width:100%; display:flex; flex-direction:column; align-items:center;">

    <!-- Blog Form -->
    <form method="POST" action="/user/notebook" style="width:100%; display:flex; justify-content:center;">
        <textarea 
            name="content"
            class="notebook" 
            placeholder="Start writing your thoughts here..."
            required
        ></textarea>
        <br>
        <button type="submit" 
            style="
                margin-top: 20px;
                padding: 10px 25px;
                font-size: 16px;
                border: none;
                border-radius: 8px;
                background: #1b365d;
                color: white;
                cursor: pointer;
            ">
            Save Blog
        </button>
    </form>

    <hr style="width:80%; margin:40px 0;">

    <!-- Saved Blogs Display -->
    <div style="width:80%;">
        <% if (blogs.length === 0) { %>
            <p style="text-align:center;">No blogs yet. Start writing ✍</p>
        <% } %>

        <% blogs.forEach(blog => { %>
            <div style="
                background: white;
                padding: 20px;
                margin-bottom: 20px;
                border-radius: 12px;
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            ">
                <p><%= blog.content %></p>
                <small style="color: gray;">
                    <%= blog.createdAt.toLocaleString() %>
                </small>
            </div>
        <% }) %>
    </div>

</div>

<script>
function toggleDarkMode() {
    document.body.classList.toggle('dark-mode');
}
</script>
</body>

</html>

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>User Dashboard</title>
<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        transition: background-color 0.3s, color 0.3s;
        background-color: #f0f4f8;
        color: #1a1a1a;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    body.dark-mode {
        background-color: #0d1b2a;
        color: #e0e0e0;
    }

    /* Header */
    .header {
        width: 100%;
        min-height: 220px;
        background: linear-gradient(135deg, #0d1b2a, #1b365d);
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-around;
        position: relative;
        text-align: center;
       /* padding: 30px 20px;*/
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
       /* border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;*/
    }

    /* Top-right buttons */
    .top-right {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .top-right button {
        padding: 8px 15px;
        font-size: 1em;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        transition: background 0.3s, color 0.3s, transform 0.2s;
    }

    .top-right button:hover {
        transform: scale(1.05);
    }

    .dark-mode-btn {
        background-color: #f0f4f8;
        color: #0d1b2a;
    }

    body.dark-mode .dark-mode-btn {
        background-color: #1b365d;
        color: #f0f4f8;
    }

    .logout-btn {
        background-color: #ff4e4e;
        color: #fff;
    }

    .logout-btn:hover {
        background-color: #e03a3a;
    }

    /* Typewriter effect */
    .typewriter h1 {
        overflow: hidden;
        border-right: .15em solid white;
        white-space: nowrap;
        animation: typing 3s steps(20, end), blink-caret 0.75s step-end infinite;
        font-size: 2.5em;
        margin: 0;
        letter-spacing: 2px;
    }

    @keyframes typing {
        from { width: 0 }
        to { width: 100% }
    }

    @keyframes blink-caret {
        50% { border-color: transparent }
    }

    /* Subheading */
    h2 {
        margin-top: 10px;
        font-size: 1.5em;
        font-weight: 500;
        color: #ffd700;
    }

    body.dark-mode .subheading {
        color: #ffcc00;
    }

    /* Navigation below header content */
    .navBar {
        margin-top: 20px;
        display: flex;
        gap: 25px;
    }

    .navBar a {
        font-size: 1.70rem;
        color: white;
        text-decoration: none;
        font-weight: 600;
        padding: 8px 15px;
        border-radius: 8px;
        transition: background 0.3s, transform 0.2s;
    }

    .navBar a:hover {
        background-color: rgba(255, 255, 255, 0.2);
        transform: scale(1.05);
    }

    /* Main content */
    .content {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        text-align: center;
    }

</style>
</head>
<body>

    <div class="header">
        <!-- Top-right buttons -->
        <div class="top-right">
            <button class="dark-mode-btn" onclick="toggleDarkMode()">Toggle Mode</button>
            <button class="logout-btn" onclick="location.href='/auth/logout'">Logout</button>
        </div>

        <!-- Welcome and user name -->
        <div class="typewriter">
            <h1>Welcome, <%= user.name %>!</h1>
       <!-- </div>
        <div class="subheading">-->
            <h2>Congratulations on being selected!</h2>
        </div>

        <!-- Navigation under header -->
        <div class="navBar">
        <a href="/user/dashboard">Home</a>
        <a href="/user/about">About</a>
        <a href="/user/notebook">Blogs</a>
        <a href="#">Contact</a>
        <a href="#">Maps</a>
</div>
    </div>

    <!-- Main content -->
    <div class="content">
        <!-- Dynamic dashboard info goes here -->
    </div>

<script>
function toggleDarkMode() {
    document.body.classList.toggle('dark-mode');
}
</script>


</body>
</html>